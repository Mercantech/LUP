---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import { forlob } from '../data/forlob';

function escapeHtml(s: string) {
  return s
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;');
}

function markdownToHtml(md: string) {
  const lines = md.split('\n');
  const out: string[] = [];
  let inList = false;

  for (const raw of lines) {
    const line = raw.trimEnd();
    if (line.startsWith('## ')) {
      if (inList) {
        out.push('</ul>');
        inList = false;
      }
      out.push(`<h3>${escapeHtml(line.slice(3))}</h3>`);
      continue;
    }
    if (line.startsWith('- ')) {
      if (!inList) {
        out.push('<ul>');
        inList = true;
      }
      out.push(`<li>${escapeHtml(line.slice(2))}</li>`);
      continue;
    }
    if (line.trim() === '') {
      if (inList) {
        out.push('</ul>');
        inList = false;
      }
      continue;
    }
    out.push(`<p>${escapeHtml(line)}</p>`);
  }

  if (inList) out.push('</ul>');
  return out.join('\n');
}
---

<BaseLayout title="LUP">
  <TopNav currentPath={Astro.url.pathname} />

  <main style="padding-top: 96px">
    <section class="hero">
      <div class="container hero__inner">
        <div class="badge mono">
          <span class="dot" aria-hidden="true"></span>
          LOKAL UNDERVISNINGSPLAN
        </div>

        <h1 class="hero__title serif">
          LUP<br />
          <span class="hero__muted"><em>PROGRAMMERING</em></span>
        </h1>

        <p class="hero__copy">
          Dokumentation af hovedforløb 1–6 med mål, indhold, didaktiske principper og evaluering.
        </p>

        <div class="hero__cta">
          <a class="btn btn--primary" href="/forlob/hovedforlob-1">
            <span>ÅBN H1</span>
          </a>
          <a class="btn" href="#roadmap">
            <span>SE OVERSIGT</span>
          </a>
        </div>

        <div class="terminal-line mono" aria-hidden="true">
          <span>$</span> lup --help <span class="cursor"></span>
        </div>
      </div>
    </section>

    <section class="section roadmap" id="roadmap">
      <div class="container roadmap__inner">
        <div class="roadmap__head">
          <h2 class="serif">Hovedforløb (oversigt)</h2>
          <p class="roadmap__sub">Scroll på siden eller hop direkte til et forløb.</p>
        </div>

        <div class="roadmap__list">
          {forlob.map((f) => (
            <a class="roadmap__item" href={`#${f.slug}`}>
              <div class="roadmap__n mono">{f.short}</div>
              <div class="roadmap__meta">
                <div class="roadmap__title serif">{f.titel}</div>
                <div class="roadmap__desc">{f.kort}</div>
              </div>
              <div class="roadmap__arrow mono">↓</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {forlob.map((f) => (
      <section class="section forlob" id={f.slug}>
        <div class="container forlob__inner">
          <div class="forlob__head">
            <div class="mono forlob__kicker">{f.short} / HOVEDFORLØB</div>
            <h2 class="serif forlob__title">{f.titel}</h2>
            <p class="forlob__lead">{f.kort}</p>
            <div class="forlob__actions">
              <a class="btn btn--primary" href={`/forlob/${f.slug}`}>
                <span>ÅBN ISOLERET</span>
              </a>
              <a class="btn" href="#roadmap">
                <span>TIL TOP</span>
              </a>
            </div>
          </div>

          <article class="forlob__content" set:html={markdownToHtml(f.markdown)} />
        </div>
      </section>
    ))}
  </main>

  <footer class="section footer">
    <div class="container footer__inner">
      <div class="mono">LUP</div>
      <div class="mono">[OK]</div>
    </div>
  </footer>

  <style>
    .hero {
      padding: 80px 0 64px;
    }

    .hero__inner {
      text-align: center;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      border: var(--border);
      border-radius: var(--radius);
      margin-bottom: 24px;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 18%, transparent);
      animation: pulse 2.2s var(--ease-editorial) infinite;
    }

    @keyframes pulse {
      0%,
      100% {
        transform: scale(1);
        opacity: 0.9;
      }
      50% {
        transform: scale(1.12);
        opacity: 1;
      }
    }

    .hero__title {
      font-weight: 300;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      line-height: 0.92;
      font-size: clamp(56px, 9vw, 120px);
      margin: 0 0 18px;
    }

    .hero__muted {
      color: var(--muted);
      font-style: italic;
      margin-inline: 8px;
    }

    .hero__copy {
      max-width: 70ch;
      margin: 0 auto 28px;
      opacity: 0.8;
    }

    .hero__cta {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .terminal-line {
      margin-top: 24px;
      opacity: 0;
      transition: opacity var(--dur-slow) var(--ease-editorial);
    }

    html[data-theme='terminal'] .terminal-line {
      opacity: 1;
      text-shadow: var(--text-glow);
    }

    .roadmap__inner {
      padding: 56px 0;
    }

    .roadmap__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 18px;
      border-bottom: var(--border);
      padding-bottom: 18px;
      margin-bottom: 18px;
    }

    .roadmap__head h2 {
      margin: 0;
      font-weight: 300;
      font-size: 32px;
    }

    .roadmap__sub {
      margin: 0;
      opacity: 0.7;
    }

    .roadmap__list {
      display: grid;
      gap: 0;
      border: var(--border);
    }

    .roadmap__item {
      display: grid;
      grid-template-columns: 72px 1fr 60px;
      gap: 16px;
      padding: 18px;
      border-bottom: var(--border);
      transition: background var(--dur-fast) var(--ease-editorial), opacity var(--dur-fast) var(--ease-editorial);
    }

    .roadmap__item:last-child {
      border-bottom: none;
    }

    .roadmap__item:hover {
      background: color-mix(in oklab, #fff 65%, var(--bg));
    }

    html[data-theme='terminal'] .roadmap__item:hover {
      background: transparent;
    }

    .roadmap__title {
      font-weight: 300;
      font-size: 18px;
      margin-bottom: 4px;
    }

    .roadmap__desc {
      opacity: 0.75;
      font-size: 14px;
    }

    .roadmap__arrow {
      text-align: right;
      align-self: center;
      opacity: 0.65;
    }

    .forlob__inner {
      padding: 56px 0;
    }

    .forlob__head {
      border-left: var(--border);
      border-right: var(--border);
      border-bottom: var(--border);
      padding: 22px;
      border-radius: var(--radius);
    }

    html[data-theme='terminal'] .forlob__head {
      border-radius: 0;
      text-shadow: var(--text-glow);
    }

    .forlob__kicker {
      opacity: 0.8;
      margin-bottom: 10px;
    }

    .forlob__title {
      font-weight: 300;
      text-transform: uppercase;
      margin: 0 0 10px;
      font-size: clamp(28px, 3.2vw, 44px);
    }

    .forlob__lead {
      margin: 0 0 14px;
      opacity: 0.8;
      max-width: 80ch;
    }

    .forlob__actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .forlob__content {
      border-left: var(--border);
      border-right: var(--border);
      border-bottom: var(--border);
      padding: 22px;
      border-radius: var(--radius);
      margin-top: 14px;
    }

    html[data-theme='terminal'] .forlob__content {
      border-radius: 0;
      text-shadow: var(--text-glow);
    }

    .forlob__content :global(h3) {
      font-family: var(--font-serif);
      font-weight: 300;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      margin: 26px 0 10px;
    }

    .forlob__content :global(p),
    .forlob__content :global(li) {
      line-height: 1.7;
      opacity: 0.9;
    }

    .forlob__content :global(ul) {
      margin: 10px 0 0;
      padding-left: 18px;
    }

    .footer__inner {
      padding: 18px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    @media (min-width: 860px) {
      .forlob__actions {
        justify-content: flex-start;
      }
    }
  </style>
</BaseLayout>

