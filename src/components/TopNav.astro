---
const { currentPath = '/' } = Astro.props;
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a class="brand" href="/">
      <span class="brand__word mono brand__ascii" aria-hidden="true">__  __ _____ ____   ____    _    _   _ _____ _____ ____</span>
      <span class="brand__word mono brand__ascii" aria-hidden="true">|  \\/  | ____|  _ \\ / ___|  / \\  | \\ | |_   _| ____/ ___|</span>
      <span class="brand__word mono brand__ascii" aria-hidden="true">| |\\/| |  _| | |_) | |     / _ \\ |  \\| | | | |  _| \\___ \\</span>
      <span class="brand__word mono brand__ascii" aria-hidden="true">| |  | | |___|  _ <| |___ / ___ \\| |\\  | | | | |___ ___) |</span>
      <span class="brand__word mono brand__ascii" aria-hidden="true">|_|  |_|_____|_| \\_\\\\____/_/   \\_\\_| \\_| |_| |_____|____/</span>
      <span class="brand__sr">Mercantec</span>
    </a>

    <nav class="nav__links mono" aria-label="Primær navigation">
      <a class:list={['nav__link', currentPath === '/' && 'is-active']} href="/">OVERSIGT</a>
      <a class:list={['nav__link', currentPath.startsWith('/forlob') && 'is-active']} href="/forlob/hovedforlob-1">H1</a>
      <a class="nav__link" href="/forlob/hovedforlob-2">H2</a>
      <a class="nav__link" href="/forlob/hovedforlob-3">H3</a>
      <a class="nav__link" href="/forlob/hovedforlob-4">H4</a>
      <a class="nav__link" href="/forlob/hovedforlob-5">H5</a>
      <a class="nav__link" href="/forlob/hovedforlob-6">H6</a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const el = document.querySelector('[data-nav]');
    if (!el) return;
    const onScroll = () => {
      const y = window.scrollY || 0;
      el.classList.toggle('is-scrolled', y > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    padding-top: 32px;
    transition: padding var(--dur-med) steps(1, end),
      background var(--dur-med) steps(1, end),
      border-color var(--dur-med) steps(1, end),
      backdrop-filter var(--dur-med) steps(1, end);
  }

  .nav.is-scrolled {
    padding-top: 0;
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: var(--border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .brand__word {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-shadow: var(--text-glow);
    line-height: 1.05;
  }

  .brand__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav__links {
    display: none;
    gap: 18px;
    align-items: center;
  }

  .nav__link {
    opacity: 0.75;
    transition: opacity var(--dur-med) steps(1, end);
    letter-spacing: 0.3em;
    font-size: 10px;
  }

  .nav__link:hover,
  .nav__link.is-active {
    opacity: 1;
  }

  html[data-theme='terminal'] .nav__link {
    text-shadow: var(--text-glow);
  }

  @media (min-width: 860px) {
    .nav__links {
      display: inline-flex;
    }
  }
</style>

